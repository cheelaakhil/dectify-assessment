# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./spacetoday.db

# Authentication
# Replace with a strong, randomly generated string in production
JWT_SECRET=development_secret_key_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# NASA API Configuration
# Get your key at https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

